msgstr "Sačuvaj podešavanja."

msgid "Dismiss"
msgstr "Odbaci"

msgid "Valeri"
msgstr "Valeri"

msgid "Hi, I'm Valeri 👋"
msgstr "Ćao, ja sam Valeri 👋"

msgid "Thanks for using this plugin."
msgstr "Hvala što koristite ovaj dodatak."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr "Ako tražite više korisnih dodataka, možete pogledati moj sajt."

msgid "If you like this plugin, I would be happy about a review."
msgstr "Ako vam se dopada ovaj dodatak, bio bih zahvalan na recenziji."

msgid "premium-plugin.com"
