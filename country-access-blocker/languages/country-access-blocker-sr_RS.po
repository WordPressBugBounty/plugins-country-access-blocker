msgid "Country"
msgstr "Zemlja"

msgid "Status"
msgstr "Status"

msgid "Block"
msgstr "Blokiraj"

msgid "Blocked"
msgstr "Blokirano"

msgid "Allowed"
msgstr "Dozvoljeno"

