msgid "Country Blocker"
msgstr "ਦੇਸ਼ ਰੋਕਣ ਵਾਲਾ"

msgid "Settings saved."
msgstr "ਸੈਟਿੰਗਜ਼ ਸੇਵ ਕੀਤੀਆਂ ਗਈਆਂ."

msgid "Unknown"
msgstr "ਅਣਜਾਣ"

msgid "Enable country blocking"
msgstr "ਦੇਸ਼ ਰੋਕਣ ਚਾਲੂ ਕਰੋ"

msgid "Enable IP-based country blocking"
msgstr "IP-ਆਧਾਰਤ ਦੇਸ਼ ਰੋਕਣ ਚਾਲੂ ਕਰੋ"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "ਇਹ ਪਲੱਗਇਨ ਸਿਰਫ ਤਦ ਚੱਲਦਾ ਹੈ ਜਦ IP-ਆਧਾਰਿਤ ਰੋਕਣ ਚਾਲੂ ਹੋਵੇ."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"IP-ਆਧਾਰਤ ਦੇਸ਼ ਰੋਕਣ ਚਾਲੂ ਕਰੋ (ip-api.com ਵਰਤਦਾ ਹੈ | 45 ਬੇਨਤੀਆਂ ਪ੍ਰਤੀ ਮਿੰਟ | "
"ਮੁਫਤ ਵਰਜਨ)"

msgid "Save settings"
msgstr "ਸੈਟਿੰਗਜ਼ ਸੇਵ ਕਰੋ"

msgid "Dismiss"
msgstr "ਬੰਦ ਕਰੋ"

msgid "Valeri"
msgstr "ਵਾਲੇਰੀ"

msgid "Hi, I'm Valeri 👋"
msgstr "ਹਾਇ, ਮੈਂ ਵਾਲੇਰੀ ਹਾਂ 👋"

msgid "Thanks for using this plugin."
msgstr "ਇਸ ਪਲੱਗਇਨ ਦੀ ਵਰਤੋਂ ਕਰਨ ਲਈ ਧੰਨਵਾਦ."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"ਜੇ ਤੁਸੀਂ ਹੋਰ ਸਹਾਇਕ ਪਲੱਗਇਨ ਲੱਭ ਰਹੇ ਹੋ, ਤਾਂ ਤੁਸੀਂ ਮੇਰੀ ਵੈੱਬਸਾਈਟ ਚੈੱਕ ਕਰ ਸਕਦੇ "
"ਹੋ."

msgid "If you like this plugin, I would be happy about a review."
msgstr ""
"ਜੇ ਤੁਸੀਂ ਇਸ ਪਲੱਗਇਨ ਨੂੰ ਪਸੰਦ ਕਰੋ, ਤਾਂ ਮੈਨੂੰ ਸਮੀਖਿਆ ਮਿਲਣ ਨਾਲ ਖੁਸ਼ੀ ਹੋਵੇਗੀ."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "ਇਸ ਪਲੱਗਇਨ ਨੂੰ ਰੇਟ ਕਰੋ"

msgid "Your detected country:"
msgstr "ਤੁਹਾਡਾ ਪਛਾਣਿਆ ਗਿਆ ਦੇਸ਼:"

msgid "Block all except my country"
msgstr "ਮੇਰੇ ਦੇਸ਼ ਨੂੰ ਛੱਡ ਕੇ ਸਾਰੇ ਰੋਕੋ."

msgid "Unblock all"
msgstr "ਸਭ ਨੂੰ ਅਨਲੌਕ ਕਰੋ"

msgid "Country"
msgstr "ਦੇਸ਼"

msgid "Status"
msgstr "ਹਾਲਤ"

msgid "Block"
msgstr "ਰੋਕੋ"

msgid "Blocked"
msgstr "ਰੋਕਿਆ ਹੋਇਆ"

msgid "Allowed"
msgstr "ਮਨਜ਼ੂਰ"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "ਤੁਹਾਡੇ ਦੇਸ਼ ਤੋਂ ਪ੍ਰਵੇਸ਼ (%s) ਨੂੰ ਰੋਕ ਦਿੱਤਾ ਗਿਆ ਹੈ."
