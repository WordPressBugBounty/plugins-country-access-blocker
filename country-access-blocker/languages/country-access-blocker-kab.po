msgstr "Ttawen tamurt yid-win yessawel"

msgid "Unblock all"
msgstr "Ennɣi awal-is"

msgid "Country"
msgstr "Tamurt"

msgid "Status"
msgstr "Tugga"

msgid "Block"
msgstr "Azzant"

msgid "Blocked"
msgstr "Akecc"

