msgid "Country Blocker"
msgstr "দেশ অবরোধকাৰী"

msgid "Settings saved."
msgstr "সেটিংসমূহ সংৰক্ষণ কৰা হৈছে."

msgid "Unknown"
msgstr "অজানা"

msgid "Enable country blocking"
msgstr "দেশ ব্লক সক্রিয় কৰক"

msgid "Enable IP-based country blocking"
msgstr "IP-ভিত্তিক দেশ ব্লক সক্রিয় কৰক"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "IP-ভিত্তিক ব্লক সক্রিয় থকা অৱস্থাতেই এই প্লাগিনটো কাৰ্য কৰে."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"IP-ভিত্তিক দেশ ব্লক সক্রিয় কৰক (ip-api.com ব্যৱহাৰ কৰে | মিনিটত 45 অনুৰোধ | "
"বিনামূলীয়া সংস্কৰণ)"

msgid "Save settings"
msgstr "সেটিংসমূহ সংৰক্ষণ কৰক"

msgid "Dismiss"
msgstr "বাতিল কৰক"

msgid "Valeri"
msgstr "ভালেৰী"

msgid "Hi, I'm Valeri 👋"
msgstr "নমস্কাৰ, মই ভালেৰী 👋"

msgid "Thanks for using this plugin."
msgstr "এই প্লাগিনটো ব্যৱহাৰ কৰাৰ বাবে ধন্যবাদ."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"আপুনি যদি আৰু সহায়ক প্লাগিন বিচাৰি থাকেন, তেনেহলে মোৰ ৱেবচাইটটো চাব পাৰে."

msgid "If you like this plugin, I would be happy about a review."
msgstr "এই প্লাগিনটো যদি আপোনাৰ পছন্দ হয়, মই এটা ৰিভিউ পালে সুখী হ'ম."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "এই প্লাগিনটো মূল্যায়ন কৰক"

msgid "Your detected country:"
msgstr "আপোনাৰ চিনাক্ত দেশ:"

msgid "Block all except my country"
msgstr "মোৰ দেশ বাদে সকলো ব্লক কৰক"

msgid "Unblock all"
msgstr "সকল ব্লক খুলক"

msgid "Country"
msgstr "দেশ"

msgid "Status"
msgstr "অৱস্থা"

msgid "Block"
msgstr "ব্লক"

msgid "Blocked"
msgstr "ব্লক কৰা"

msgid "Allowed"
msgstr "অনুমোদিত"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "আপোনাৰ দেশ (%s) পৰা প্ৰৱেশ ব্লক কৰা হৈছে."
