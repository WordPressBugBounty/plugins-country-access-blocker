msgid "Country Blocker"
msgstr "देश ब्लॉकर"

msgid "Settings saved."
msgstr "सेटिङहरू सुरक्षित गरियो।"

msgid "Unknown"
msgstr "अज्ञात"

msgid "Enable country blocking"
msgstr "देश अवरोध सक्षम गर्नुहोस्"

msgid "Enable IP-based country blocking"
msgstr "IP-आधारित देश अवरोध सक्षम गर्नुहोस्"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "IP-आधारित अवरोध सक्षम भएको अवस्थामा मात्र यो प्लगइन चल्छ।"

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"IP-आधारित देश अवरोध सक्षम गर्नुहोस् (ip-api.com प्रयोग गर्दछ | प्रति मिनेट "
"45 अनुरोध | निःशुल्क संस्करण)"

msgid "Save settings"
msgstr "सेटिङहरू सुरक्षित गर्नुहोस्"

msgid "Dismiss"
msgstr "खारिज गर्नुहोस्"

msgid "Valeri"
msgstr "Valeri"

msgid "Hi, I'm Valeri 👋"
msgstr "नमस्ते, म Valeri 👋"

msgid "Thanks for using this plugin."
msgstr "यस प्लगइनको प्रयोग गर्नु भएकोमा धन्यवाद।"

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"यदि तपाईं अझ बढी उपयोगी प्लगइनहरू खोज्दै हुनुहुन्छ भने, तपाईं मेरो वेबसाइट "
"हेर्न सक्नुहुन्छ।"

msgid "If you like this plugin, I would be happy about a review."
msgstr "यो प्लगइन मन परेमा, कृपया समीक्षा गर्नुहोस् भने मेरो खुशी हुनेछु।"

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "यो प्लगइनलाई दर गर्नुहोस्"

msgid "Your detected country:"
msgstr "तपाईंले पत्ता लगाएको देश:"

msgid "Block all except my country"
msgstr "मेरो देश बाहेक सबैलाई ब्लक गर्नुहोस्"

msgid "Unblock all"
msgstr "सबै ब्लक हटाउनुहोस्"

msgid "Country"
msgstr "देश"

msgid "Status"
msgstr "स्थिति"

msgid "Block"
msgstr "ब्लक गर्नुहोस्"

msgid "Blocked"
msgstr "ब्लक गरिएको"

msgid "Allowed"
msgstr "स्वीकृत"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "तपाईंको देश (%s) बाट पहुँच ब्लक गरिएको छ।"
