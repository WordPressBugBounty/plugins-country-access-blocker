msgid "Country Blocker"
msgstr "Chặn quốc gia"

msgid "Settings saved."
msgstr "Đã lưu cài đặt."

msgid "Unknown"
msgstr "Chưa xác định"

msgid "Enable country blocking"
msgstr "Bật chặn quốc gia"

msgid "Enable IP-based country blocking"
msgstr "Bật chặn quốc gia dựa trên IP"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "Tiện ích này chỉ hoạt động khi bật chặn dựa trên IP."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"Bật chặn quốc gia dựa trên IP (sử dụng ip-api.com | 45 yêu cầu mỗi phút | "
"Phiên bản miễn phí)"

msgid "Save settings"
msgstr "Lưu cài đặt"

msgid "Dismiss"
msgstr "Đóng"

msgid "Valeri"
msgstr "Valeri"

msgid "Hi, I'm Valeri 👋"
msgstr "Chào bạn, mình là Valeri 👋"

msgid "Thanks for using this plugin."
msgstr "Cảm ơn bạn đã sử dụng plugin này."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"Nếu bạn đang tìm kiếm các plugin hữu ích hơn, bạn có thể xem trang web của "
"tôi."

msgid "If you like this plugin, I would be happy about a review."
msgstr "Nếu bạn thích plugin này, tôi rất vui được nhận một đánh giá."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "Đánh giá plugin này."

msgid "Your detected country:"
msgstr "Quốc gia bạn đã phát hiện:"

msgid "Block all except my country"
msgstr "Chặn tất cả ngoại trừ quốc gia của tôi."

msgid "Unblock all"
msgstr "Gỡ chặn tất cả"

msgid "Country"
msgstr "Quốc gia"

msgid "Status"
msgstr "Trạng thái"

msgid "Block"
msgstr "Chặn"

msgid "Blocked"
msgstr "Đã bị chặn"

msgid "Allowed"
msgstr "Được cho phép"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "Truy cập từ quốc gia của bạn (%s) đã bị chặn."
