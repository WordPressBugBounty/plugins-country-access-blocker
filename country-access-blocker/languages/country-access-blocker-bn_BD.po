msgid "Country Blocker"
msgstr "দেশ ব্লকার"

msgid "Settings saved."
msgstr "সেটিংস সংরক্ষিত হয়েছে।"

msgid "Unknown"
msgstr "অজানা"

msgid "Enable country blocking"
msgstr "দেশ ব্লকিং সক্ষম করুন"

msgid "Enable IP-based country blocking"
msgstr "IP-ভিত্তিক দেশ ব্লকিং সক্ষম করুন"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "এই প্লাগইনটি কেবল তখনই কাজ করবে যখন IP-ভিত্তিক ব্লকিং সক্ষম থাকবে।"

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"IP-ভিত্তিক দেশ ব্লকিং সক্ষম করুন (ip-api.com ব্যবহার করে | প্রতি মিনিটে 45 "
"অনুরোধ | ফ্রি সংস্করণ)"

msgid "Save settings"
msgstr "সেটিংস সংরক্ষণ করুন"

msgid "Dismiss"
msgstr "বাতিল করুন"

msgid "Valeri"
msgstr "ভ্যালারি"

msgid "Hi, I'm Valeri 👋"
msgstr "হাই, আমি ভ্যালারি 👋"

msgid "Thanks for using this plugin."
msgstr "এই প্লাগইনটি ব্যবহার করার জন্য ধন্যবাদ।"

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"আপনি যদি আরও সহায়ক প্লাগিন খুঁজে থাকেন, তবে আমার ওয়েবসাইটটি দেখতে পারেন।"

msgid "If you like this plugin, I would be happy about a review."
msgstr "এই প্লাগইনটি আপনাকে ভালো লাগলে একটি রিভিউ পেলে আমি খুশি হব।"

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "এই প্লাগইনটি রেট দিন"

msgid "Your detected country:"
msgstr "আপনার শনাক্ত দেশ:"

msgid "Block all except my country"
msgstr "আমার দেশের বাইরে থাকা সব দেশ ব্লক করুন"

msgid "Unblock all"
msgstr "সব আনব্লক করুন"

msgid "Country"
msgstr "দেশ"

msgid "Status"
msgstr "অবস্থা"

msgid "Block"
msgstr "ব্লক"

msgid "Blocked"
msgstr "ব্লক করা হয়েছে"

msgid "Allowed"
msgstr "অনুমোদিত"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "আপনার দেশের (%s) থেকে অ্যাক্সেস ব্লক করা হয়েছে।"
