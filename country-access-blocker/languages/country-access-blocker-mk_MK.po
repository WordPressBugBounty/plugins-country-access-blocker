msgid "Country Blocker"
msgstr "Блокатор на земји"

msgid "Settings saved."
msgstr "Поставките се зачувани."

msgid "Unknown"
msgstr "Непознато"

msgid "Enable country blocking"
msgstr "Вклучи блокирање на земји"

msgid "Enable IP-based country blocking"
msgstr "Вклучи IP-базирано блокирање на земји"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "Овој плагин работи само ако е овозможено IP-базирано блокирање."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"Вклучи IP-базирано блокирање на земји (користи ip-api.com | 45 барања на "
"минута | Бесплатна верзија)"

msgid "Save settings"
msgstr "Зачувај поставки"

msgid "Dismiss"
msgstr "Откажи"

msgid "Valeri"
msgstr "Валери"

msgid "Hi, I'm Valeri 👋"
msgstr "Здраво, јас сум Валери 👋"

msgid "Thanks for using this plugin."
msgstr "Ви благодариме што го користите овој плагин."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"Ако барате повеќе корисни плагини, можете да ја посетите мојата веб-"
"страница."

msgid "If you like this plugin, I would be happy about a review."
msgstr "Ако ви се допаѓа овој плагин, ќе бидам среќен ако оставите рецензија."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "Оцени го овој плагин."

msgid "Your detected country:"
msgstr "Вашата откриена земја:"

msgid "Block all except my country"
msgstr "Блокирај ги сите освен мојата земја."

msgid "Unblock all"
msgstr "Разблокирај ги сите."

msgid "Country"
msgstr "Земја"

msgid "Status"
msgstr "Статус"

msgid "Block"
msgstr "Блокирај"

msgid "Blocked"
msgstr "Блокирано"

msgid "Allowed"
msgstr "Дозволено"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "Достапот од вашата земја (%s) е блокиран."
