msgid "Country Blocker"
msgstr "দেশ ব্লকার"

msgid "Settings saved."
msgstr "সেটিংস সংরক্ষণ করা হয়েছে।"

msgid "Unknown"
msgstr "অজানা"

msgid "Enable country blocking"
msgstr "দেশ ব্লকিং সক্ষম করুন"

msgid "Enable IP-based country blocking"
msgstr "IP-ভিত্তিক দেশের ব্লকিং সক্ষম করুন"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "IP-ভিত্তিক ব্লকিং সক্রিয় থাকলে এই প্লাগিনটি কাজ করবে।"

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"IP-ভিত্তিক দেশের ব্লকিং সক্ষম করুন (ip-api.com ব্যবহার করে | মিনিটে 45 "
"অনুরোধ | ফ্রি সংস্করণ)"

msgid "Save settings"
msgstr "সেটিংস সংরক্ষণ করুন"

msgid "Dismiss"
msgstr "বাতিল"

msgid "Valeri"
msgstr "ভ্যালারি"

msgid "Hi, I'm Valeri 👋"
msgstr "হাই, আমি ভ্যালারি 👋"

msgid "Thanks for using this plugin."
msgstr "এই প্লাগইন ব্যবহারের জন্য ধন্যবাদ।"

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr "আরও সহায়ক প্লাগইন খুঁজলে, আপনি আমার ওয়েবসাইটটি দেখতে পারেন।"

msgid "If you like this plugin, I would be happy about a review."
msgstr "এই প্লাগইনটি পছন্দ করলে, একটি রিভিউ দিলে আমি খুশি হব।"

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "এই প্লাগইনটি রেট দিন"

msgid "Your detected country:"
msgstr "আপনার সনাক্ত দেশ:"

msgid "Block all except my country"
msgstr "আমার দেশের বাইরে সব ব্লক করুন"

msgid "Unblock all"
msgstr "সব আনব্লক করুন"

msgid "Country"
msgstr "দেশ"

msgid "Status"
msgstr "অবস্থা"

msgid "Block"
msgstr "ব্লক"

msgid "Blocked"
msgstr "ব্লক হয়েছে"

msgid "Allowed"
msgstr "অনুমোদিত"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "আপনার দেশের (%s) থেকে প্রবেশ ব্লক করা হয়েছে।"
