msgid "Country Blocker"
msgstr "രാജ്യം തടയാനുള്ള സംവിധാനം"

msgid "Settings saved."
msgstr "സജ്ജീകരണങ്ങൾ محفوظമായി."

msgid "Unknown"
msgstr "അറിയില്ല"

msgid "Enable country blocking"
msgstr "രാജ്യം തടയൽ സജീവമാക്കുക"

msgid "Enable IP-based country blocking"
msgstr "IP-അടിസ്ഥാനത്തിലുള്ള രാജ്യ തടയൽ സജീവമാക്കുക"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr ""
"IP-അടിസ്ഥാനത്തിലുള്ള ബ്ലോക്കിംഗ് സജീവമാക്കിയാലേ ഈ പ്ലഗിൻ പ്രവർത്തിക്കും."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"IP-അടിസ്ഥാനത്തിലുള്ള രാജ്യ തടയൽ സജീവമാക്കുക (ip-api.com ഉപയോഗിക്കുന്നു | "
"മിനിറ്റിൽ 45 അഭ്യർത്ഥനകൾ | ഫ്രീ വേർഷൻ)"

msgid "Save settings"
msgstr "സജ്ജീകരണങ്ങൾ സേവ് ചെയ്യുക"

msgid "Dismiss"
msgstr "റദ്ദാക്കുക"

msgid "Valeri"
msgstr "വാലരി"

msgid "Hi, I'm Valeri 👋"
msgstr "ഹൈ, ഞാൻ വാലരി 👋"

msgid "Thanks for using this plugin."
msgstr "ഈ പ്ലഗിൻ ഉപയോഗിച്ചതിന് നന്ദി."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr "കൂടുതൽ സഹായക പ്ലഗിനുകൾ തേടുകയാണെങ്കിൽ, എന്റെ വെബ്സൈറ്റ് പരിശോധിക്കാം."

msgid "If you like this plugin, I would be happy about a review."
msgstr ""
"ഈ പ്ലഗിൻ നിങ്ങൾ ഇഷ്ടപ്പെടുന്നുവെങ്കിൽ, ഒരു റിവ്യൂ നൽകുന്നത് എനിക്ക് സന്തോഷം "
"ചെയ്യും."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "ഈ പ്ലഗിൻ റേറ്റ് ചെയ്യുക"

msgid "Your detected country:"
msgstr "നിങ്ങളുടെ കണ്ടെത്തിയ രാജ്യം:"

msgid "Block all except my country"
msgstr "എന്റെ രാജ്യം ഒഴികെയുള്ള എല്ലാ രാജ്യങ്ങളും ബ്ലോക്ക് ചെയ്യുക"

msgid "Unblock all"
msgstr "എല്ലാം അൺബ്ലോക്ക് ചെയ്യുക"

msgid "Country"
msgstr "രാജ്യം"

msgid "Status"
msgstr "സ്ഥിതി"

msgid "Block"
msgstr "തടയുക"

msgid "Blocked"
msgstr "തടഞ്ഞത്"

msgid "Allowed"
msgstr "അനുവദിക്കപ്പെട്ടു"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "നിങ്ങളുടെ രാജ്യത്ത് (%s) നിന്നുള്ള ആക്‌സസ് തടയപ്പെട്ടു."
