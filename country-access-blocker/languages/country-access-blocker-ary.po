msgid "Country Blocker"
msgstr "حاجز الدول"

msgid "Settings saved."
msgstr "تم حفظ الإعدادات."

msgid "Unknown"
msgstr "غير معروف"

msgid "Enable country blocking"
msgstr "تفعيل حظر الدول"

msgid "Enable IP-based country blocking"
msgstr "تفعيل حظر الدول باستخدام IP"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "هاد البلوجين كا يخدم غير إلا تفعّل حظر الدول باستخدام IP."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"تفعيل حظر الدول باستخدام IP (يستعمل ip-api.com | 45 طلباً في الدقيقة | "
"النسخة المجانية)"

msgid "Save settings"
msgstr "حفظ الإعدادات"

msgid "Dismiss"
msgstr "إغلاق"

msgid "Valeri"
msgstr "فاليري"

msgid "Hi, I'm Valeri 👋"
msgstr "مرحبا، أنا فاليري 👋"

msgid "Thanks for using this plugin."
msgstr "شكراً لاستخدامك هذا البلوجين."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr "إذا كنت تبحث عن إضافات أكثر فائدة، يمكنك زيارة موقعي."

msgid "If you like this plugin, I would be happy about a review."
msgstr "إذا عجبك هاد البلوجين، سأكون سعيداً بتقييمك."

msgid "premium-plugin.com"
