msgstr "حجب الكل باستثناء بلدي"

msgid "Unblock all"
msgstr "فتح الكل"

msgid "Country"
msgstr "البلد"

msgid "Status"
msgstr "الحالة"

msgid "Block"
msgstr "حظر"

msgid "Blocked"
msgstr "محظور"

msgid "Allowed"
msgstr "مسموح"

