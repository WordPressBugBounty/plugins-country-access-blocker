msgid "Country Blocker"
msgstr "Pangblokir Negara"

msgid "Settings saved."
msgstr "Setelan wis disimpen."

msgid "Unknown"
msgstr "Ora dingerteni."

msgid "Enable country blocking"
msgstr "Nyalakaké pemblokiran negara."

msgid "Enable IP-based country blocking"
msgstr "Nyalakaké pemblokiran negara adhedhasar IP."

msgid "This plugin works only when IP-based blocking is enabled."
msgstr ""
"Plugin iki mung bisa digunakake yen pemblokiran adhedhasar IP diaktifake."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"Nyalakaké pemblokiran negara adhedhasar IP (nganggo ip-api.com | 45 "
"panyuwunan per menit | Versi Gratis)"

msgid "Save settings"
msgstr "Simpen setelan."

msgid "Dismiss"
msgstr "Abaikan."

msgid "Valeri"
msgstr "Valeri"

msgid "Hi, I'm Valeri 👋"
msgstr "Halo, aku Valeri 👋"

msgid "Thanks for using this plugin."
msgstr "Matur nuwun wis nggunakake plugin iki."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"Yen sampeyan nggoleki plugin liyane sing luwih migunani, sampeyan bisa "
"mriksa situs webku."

msgid "If you like this plugin, I would be happy about a review."
msgstr ""
"Yen sampeyan seneng karo plugin iki, aku bakal seneng yen menehi ulasan."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "Nilai plugin iki."

msgid "Your detected country:"
msgstr "Negaramu sing dideteksi:"

msgid "Block all except my country"
msgstr "Blokir kabeh kajaba negaraku."

msgid "Unblock all"
msgstr "Mbukak kabeh blokir."

msgid "Country"
msgstr "Negara"

msgid "Status"
msgstr "Kahanan"

msgid "Block"
msgstr "Blokir."

msgid "Blocked"
msgstr "Diblokir."

msgid "Allowed"
msgstr "Diijini."

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "Akses saka negara sampeyan (%s) wis diblokir."
