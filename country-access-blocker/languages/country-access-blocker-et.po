msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"Luba IP-põhine riigi blokeerimine (kasutab ip-api.com | 45 päringut minutis "
"| Tasuta versioon)"

msgid "Save settings"
msgstr "Salvesta seaded."

msgid "Dismiss"
msgstr "Sulge"

msgid "Valeri"
msgstr "Valeri"

msgid "Hi, I'm Valeri 👋"
msgstr "Tere, olen Valeri 👋"

msgid "Thanks for using this plugin."
msgstr "Aitäh selle pistikprogrammi kasutamise eest."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"Kui otsite veel kasulikke pistikprogramme, võite külastada minu veebisaiti."

msgid "If you like this plugin, I would be happy about a review."
msgstr "Kui see pistikprogramm sulle meeldib, oleksin arvustuse eest tänulik."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "Hinda seda pistikprogrammi."

msgid "Your detected country:"
