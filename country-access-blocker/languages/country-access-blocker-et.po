msgstr "Eemalda blokeering kõigi jaoks."

msgid "Country"
msgstr "Riik"

msgid "Status"
msgstr "Staatus"

msgid "Block"
msgstr "Blokeeri"

msgid "Blocked"
msgstr "Blokeeritud"

msgid "Allowed"
msgstr "Lubatud"

