msgid "Country Blocker"
msgstr "Блокування за країною"

msgid "Settings saved."
msgstr "Налаштування збережено."

msgid "Unknown"
msgstr "Невідомо"

msgid "Enable country blocking"
msgstr "Увімкнути блокування за країною"

msgid "Enable IP-based country blocking"
msgstr "Увімкнути блокування країн за IP-адресою"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "Цей плагін працює лише за умови увімненого блокування за IP-адресою."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"Увімкнути блокування країн за IP-адресою (використовує ip-api.com | 45 "
"запитів за хвилину | Безкоштовна версія)"

msgid "Save settings"
msgstr "Зберегти налаштування"

msgid "Dismiss"
msgstr "Закрити"

msgid "Valeri"
msgstr "Валерій"

msgid "Hi, I'm Valeri 👋"
msgstr "Привіт, я Валерій 👋"

msgid "Thanks for using this plugin."
msgstr "Дякую за використання цього плагіна."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"Якщо ви шукаєте більше корисних плагінів, ви можете переглянути мій сайт."

msgid "If you like this plugin, I would be happy about a review."
msgstr "Якщо вам подобається цей плагін, буду радий отримати відгук."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "Оцініть цей плагін."

msgid "Your detected country:"
msgstr "Ваша визначена країна:"

msgid "Block all except my country"
msgstr "Блокувати все, крім моєї країни"

msgid "Unblock all"
msgstr "Розблокувати все"

msgid "Country"
msgstr "Країна"

msgid "Status"
msgstr "Статус"

msgid "Block"
msgstr "Блокувати"

msgid "Blocked"
msgstr "Заблоковано"

msgid "Allowed"
msgstr "Дозволено"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "Доступ з вашої країни (%s) заблоковано."
