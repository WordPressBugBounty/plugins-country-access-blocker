msgid "Country Blocker"
msgstr "បិទប្រទេស"

msgid "Settings saved."
msgstr "ការកំណត់បានរក្សាទុក។"

msgid "Unknown"
msgstr "មិនដឹង"

msgid "Enable country blocking"
msgstr "បើកការបិទប្រទេស"

msgid "Enable IP-based country blocking"
msgstr "បើកការបិទប្រទេសផ្អែកលើ IP"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "កម្មវិធីនេះដំនើរការបានតែពេលដែលការបិទផ្អែកលើ IP ត្រូវបានបើក។"

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"បើកការបិទប្រទេសផ្អែកលើ IP (ប្រើ ip-api.com | 45 សំណើរ/នាទី | កំណែឥតគិត)"

msgid "Save settings"
msgstr "រក្សាទុកការកំណត់"

msgid "Dismiss"
msgstr "បោះបង់"

msgid "Valeri"
msgstr "Valeri"

msgid "Hi, I'm Valeri 👋"
msgstr "សួស្តី, ខ្ញុំគឺ Valeri 👋"

msgid "Thanks for using this plugin."
msgstr "សូមអរគុណដែលបានប្រើកម្មវិធីនេះ។"

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"បើអ្នកកំពុងស្វែងរក Plugin ដែលមានប្រយោជន៍បន្ថែម អ្នកអាចមើលវេបសាយរបស់ខ្ញុំបាន。"

msgid "If you like this plugin, I would be happy about a review."
msgstr "ប្រសិនបើអ្នកចូលចិត្ត Plugin នេះ ខ្ញុំរីករាយទទួលបានមតិយោបល់。"

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "វាយតម្លៃ plugin នេះ"

msgid "Your detected country:"
msgstr "ប្រទេសដែលអ្នកបានរកឃើញ៖"

msgid "Block all except my country"
msgstr "បិទទាំងអស់ លើកលែងពីប្រទេសរបស់ខ្ញុំ"

msgid "Unblock all"
msgstr "ដោះបិទទាំងអស់"

msgid "Country"
msgstr "ប្រទេស"

msgid "Status"
msgstr "ស្ថានភាព"

msgid "Block"
msgstr "បិទ"

msgid "Blocked"
msgstr "បានបិទ"

msgid "Allowed"
msgstr "អនុញ្ញាត"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "ការចូលពីប្រទេសរបស់អ្នក (%s) ត្រូវបានបិទ។"
