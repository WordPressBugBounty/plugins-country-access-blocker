msgid "Country Blocker"
msgstr "ქვეყნის ბლოკერი"

msgid "Settings saved."
msgstr "პარამეტრები შენახულია."

msgid "Unknown"
msgstr "უცნობი"

msgid "Enable country blocking"
msgstr "ქვეყნის დაბლოკვის ჩართვა"

msgid "Enable IP-based country blocking"
msgstr "IP-დამყარებული ქვეყნების დაბლოკვის ჩართვა"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr ""
"ეს პლაგინი მუშაობს მხოლოდ მაშინ, როდესაც IP-დამყარებული დაბლოკვა ჩართულია."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"IP-დამყარებული ქვეყნების დაბლოკვის ჩართვა (ip-api.com | წუთში 45 მოთხოვნები "
"| უფასო ვერსია)"

msgid "Save settings"
msgstr "პარამეტრების შენახვა."

msgid "Dismiss"
msgstr "გაუქმება"

msgid "Valeri"
msgstr "ვალერი"

msgid "Hi, I'm Valeri 👋"
msgstr "გამარჯობა, მე ვარ ვალერი 👋"

msgid "Thanks for using this plugin."
msgstr "გმადლობთ, რომ იყენებთ ამ პლაგინს."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr "თუ მეტი სასარგებლო პლაგინები გსურთ, შეგიძლიათ ნახოთ ჩემი საიტი."

msgid "If you like this plugin, I would be happy about a review."
msgstr "თუ მოგწონთ ეს პლაგინი, ძალიან დავაფასებ შეფასებას."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "ეს პლაგინი შეაფასეთ."

msgid "Your detected country:"
msgstr "გამოცნობილი ქვეყანა:"

msgid "Block all except my country"
msgstr "ყველაფერს დაბლოკე, გარდა ჩემს ქვეყნის."

msgid "Unblock all"
msgstr "გაანბლოკე ყველაფერი."

msgid "Country"
msgstr "ქვეყანა"

msgid "Status"
msgstr "სტატუსი"

msgid "Block"
msgstr "დაბლოკვა"

msgid "Blocked"
msgstr "დაბლოკილი"

msgid "Allowed"
msgstr "დაშვებულია"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "თქვენს ქვეყანაში (%s) წვდომა დაბლოკილია."
