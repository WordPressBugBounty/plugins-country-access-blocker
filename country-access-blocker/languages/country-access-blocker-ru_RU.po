msgid "Block all except my country"
msgstr "Блокировать всё, кроме моей страны"

msgid "Unblock all"
msgstr "Разблокировать всё"

msgid "Country"
msgstr "Страна"

msgid "Status"
msgstr "Статус"

msgid "Block"
msgstr "Заблокировать"

msgid "Blocked"
msgstr "Заблокировано"

msgid "Allowed"
msgstr "Разрешено"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "Доступ из вашей страны (%s) заблокирован."
