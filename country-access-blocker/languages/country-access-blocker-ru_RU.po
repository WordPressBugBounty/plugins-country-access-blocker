msgid "Country Blocker"
msgstr "Блокировщик стран"

msgid "Settings saved."
msgstr "Настройки сохранены."

msgid "Unknown"
msgstr "Неизвестно"

msgid "Enable country blocking"
msgstr "Включить блокировку по стране"

msgid "Enable IP-based country blocking"
msgstr "Включить IP-блокировку по стране"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "Этот плагин работает только при включённой IP-блокировке."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"Включить IP-блокировку по стране (использует ip-api.com | 45 запросов в "
"минуту | Бесплатная версия)"

msgid "Save settings"
msgstr "Сохранить настройки"

msgid "Dismiss"
msgstr "Закрыть"

msgid "Valeri"
msgstr "Валери"

msgid "Hi, I'm Valeri 👋"
msgstr "Привет, я Валери 👋"

msgid "Thanks for using this plugin."
msgstr "Спасибо, что пользуетесь этим плагином."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr "Если вы ищете другие полезные плагины, вы можете посетить мой сайт."

msgid "If you like this plugin, I would be happy about a review."
msgstr "Если вам нравится этот плагин, буду рад получить отзыв."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "Оцените этот плагин"

msgid "Your detected country:"
