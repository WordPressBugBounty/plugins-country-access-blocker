msgid "Unblock all"
msgstr "Odblokiraj vse."

msgid "Country"
msgstr "Država"

msgid "Status"
msgstr "Status"

msgid "Block"
msgstr "Blokiraj"

msgid "Blocked"
msgstr "Blokirano"

msgid "Allowed"
msgstr "Dovoljeno"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "Dostop iz vaše države (%s) je blokiran."
