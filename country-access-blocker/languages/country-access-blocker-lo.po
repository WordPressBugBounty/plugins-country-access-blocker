msgid "Country Blocker"
msgstr "ຜູ້ກຳກັດປະເທດ"

msgid "Settings saved."
msgstr "ການຕັ້ງຄ່າຖືກບັນທຶກແລ້ວ."

msgid "Unknown"
msgstr "ບໍ່ຮູ້"

msgid "Enable country blocking"
msgstr "ເປີດການກັດປະເທດ"

msgid "Enable IP-based country blocking"
msgstr "ເປີດການກັດປະເທດອີພີ"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "ໂຄງສະນານນີ້ ຈະຮອດເຮັດວຽກກັດປະເທດອິພີເມື່ອການເປີດ."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"ເປີດການກັດປະເທດອິພີ (ໃຊ້ ip-api.com | 45 ການຮ້ອງຂໍຕໍ່ນານ | Version Free)"

msgid "Save settings"
msgstr "ບັນທຶກການຕັ້ງຄ່າ"

msgid "Dismiss"
msgstr "ຍົກເລີກ"

msgid "Valeri"
msgstr "Valeri"

msgid "Hi, I'm Valeri 👋"
msgstr "ສະບາຍດີ, ຂ້ອຍ Valeri 👋"

msgid "Thanks for using this plugin."
msgstr "ຂອບໃຈທີ່ໃຊ້ສິງນີ້."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"ຖ້າທ່ານກຳລັງຫາ plugin ທີ່ມີປະໂຫຍດກວ່ານີ້, ທ່ານສາມາດເຊັກເຊື່ອມເວັບຂອງຂ້ອຍ."

msgid "If you like this plugin, I would be happy about a review."
msgstr "ຖ້າທ່ານຕ້ອນທານກັບສິງນີ້, ຂ້ອຍຈະມີຄວາມຍອນກິດເລີນ."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "ປະເມີນ pluginນີ້"

msgid "Your detected country:"
msgstr "ປະເທດທີ່ທ່ານສະແກນ:"

msgid "Block all except my country"
msgstr "ກັດປະເທດທັງຫມູ່ຍອກນອກຈາກປະເທດຂອງຂ້ອຍ"

msgid "Unblock all"
msgstr "ເປີດການອະນຸຍາດທັງຫມູ່"

msgid "Country"
msgstr "ປະເທດ"

msgid "Status"
msgstr "ສະຖານະ"

msgid "Block"
msgstr "ກັດກອນ"

msgid "Blocked"
msgstr "ຖືກກອດ"

msgid "Allowed"
msgstr "ອະນຸຍາດ"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "ການເຂົ້າຈາກປະເທດຂອງທ່ານ (%s) ໄດ້ຖືກກັດ."
