msgid "Country Blocker"
msgstr "Kizuia Nchi"

msgid "Settings saved."
msgstr "Mipangilio imehifadhiwa"

msgid "Unknown"
msgstr "Isiyojulikana"

msgid "Enable country blocking"
msgstr "Washa uzuiaji wa nchi"

msgid "Enable IP-based country blocking"
msgstr "Washa uzuiaji wa nchi kwa IP"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "Plugin hii hufanya kazi tu ikiwa uzuiaji wa IP umewashwa"

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"Washa uzuiaji wa nchi kwa kutumia IP (inatumia ip-api.com | maombi 45 kwa "
"dakika | Toleo la Bure)"

msgid "Save settings"
msgstr "Hifadhi mipangilio"

msgid "Dismiss"
msgstr "Funga"

msgid "Valeri"
msgstr "Valeri"

msgid "Hi, I'm Valeri 👋"
msgstr "Hujambo, mimi ni Valeri 👋"

msgid "Thanks for using this plugin."
msgstr "Asante kwa kutumia kiendelezi hiki"

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"Ikiwa unatafuta kiendelezi zaidi yenye msaada, unaweza kutembelea tovuti "
"yangu"

msgid "If you like this plugin, I would be happy about a review."
msgstr "Ikiwa unapenda kiendelezi hiki, ningefurahi ikiwa utanipa tathmini"

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "Toa tathmini kwa kiendelezi hiki"

msgid "Your detected country:"
msgstr "Nchi uliogunduliwa:"

msgid "Block all except my country"
msgstr "Zuia yote isipokuwa nchi yangu"

msgid "Unblock all"
msgstr "Ondoa vizuizi vyote"

msgid "Country"
msgstr "Nchi"

msgid "Status"
msgstr "Hali"

msgid "Block"
msgstr "Zuia"

msgid "Blocked"
msgstr "Zuiliwa"

msgid "Allowed"
msgstr "Ruhusiwa"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "Upatikanaji kutoka nchi yako (%s) umezuiwa"
