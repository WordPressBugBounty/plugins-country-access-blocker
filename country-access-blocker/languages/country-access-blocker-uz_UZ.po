msgid "Country Blocker"
msgstr "Mamlakat blokirovchisi"

msgid "Settings saved."
msgstr "Sozlamalar saqlandi."

msgid "Unknown"
msgstr "Noma'lum"

msgid "Enable country blocking"
msgstr "Mamlakat bloklashini yoqing"

msgid "Enable IP-based country blocking"
msgstr "IP-ga asoslangan mamlakat bloklashini yoqing"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "Ushbu plagin IP-ga asoslangan bloklash yoqilgan bo'lganda ishlaydi."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"IP-ga asoslangan mamlakat bloklashini yoqing (ip-api.com orqali | daqiqada "
"45 ta so'rov | Bepul versiya)"

msgid "Save settings"
msgstr "Sozlamalarni saqlang"

msgid "Dismiss"
msgstr "Bekor qilish"

msgid "Valeri"
msgstr "Valeri"

msgid "Hi, I'm Valeri 👋"
msgstr "Salom, men Valeri 👋"

msgid "Thanks for using this plugin."
msgstr "Ushbu plaginni ishlatganingiz uchun rahmat."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"Agar siz yana foydali plaginlarni izlayotgan bo'lsangiz, mening veb-saytimga"
" tashrif buyuring."

msgid "If you like this plugin, I would be happy about a review."
msgstr ""
"Agar bu plagin sizga yoqsa, izoh qoldirishingizdan xursand bo'lar edim."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "Ushbu plagin uchun reyting bering."

msgid "Your detected country:"
msgstr "Aniqlangan mamlakatingiz:"

msgid "Block all except my country"
msgstr "Mening mamlakatimdan tashqari barcha mamlakatlarni bloklash"

msgid "Unblock all"
msgstr "Barcha blokirovkalarni bekor qilish"

msgid "Country"
msgstr "Mamlakat"

msgid "Status"
msgstr "Holat"

msgid "Block"
msgstr "Bloklash"

msgid "Blocked"
msgstr "Bloklangan"

msgid "Allowed"
msgstr "Ruxsat berilgan"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "Sizning mamlakatingizdan kirish (%s) bloklandi."
