msgstr "Afblokkaðu allt"

msgid "Country"
msgstr "Land"

msgid "Status"
msgstr "Staða"

msgid "Block"
msgstr "Blocka"

msgid "Blocked"
msgstr "Blokkað"

msgid "Allowed"
msgstr "Leyfilegt"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "Aðgangur frá landi þínu (%s) hefur verið blokkaður."
