msgstr "Virkja landablokkun"

msgid "Enable IP-based country blocking"
msgstr "Virkja IP-tengd landablokkun"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "Þessi viðbót virkar aðeins þegar IP-tengd blokkun er virk."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"Virkja IP-tengd landablokkun (notar ip-api.com | 45 beiðnir á mínútu | "
"Ókeypis útgáfa)"

msgid "Save settings"
msgstr "Vista stillingar."

msgid "Dismiss"
msgstr "Hunsa"

msgid "Valeri"
msgstr "Valeri"

msgid "Hi, I'm Valeri 👋"
msgstr "Halló, ég er Valeri 👋"

msgid "Thanks for using this plugin."
msgstr "Takk fyrir að nota þennan viðbót."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"Ef þú ert að leita að fleiri gagnlegar viðbætur, getur þú skoðað vefsíðuna "
"mína."

msgid "If you like this plugin, I would be happy about a review."
msgstr "Ef þér líkar við þessa viðbót, myndi ég vera glaður fyrir umsögn."

