msgid "Country Blocker"
msgstr "Blokátor krajín"

msgid "Settings saved."
msgstr "Nastavenia uložené."

msgid "Unknown"
msgstr "Neznámy"

msgid "Enable country blocking"
msgstr "Povoliť blokovanie krajín"

msgid "Enable IP-based country blocking"
msgstr "Povoliť blokovanie krajín podľa IP"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr ""
"Tento plugin funguje len vtedy, keď je povolené blokovanie na základe IP."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"Povoliť blokovanie krajín podľa IP (používa ip-api.com | 45 požiadaviek za "
"minútu | Bezplatná verzia)"

msgid "Save settings"
msgstr "Uložiť nastavenia"

msgid "Dismiss"
msgstr "Zrušiť"

msgid "Valeri"
msgstr "Valeri"

msgid "Hi, I'm Valeri 👋"
msgstr "Ahoj, som Valeri 👋"

msgid "Thanks for using this plugin."
msgstr "Ďakujem za používanie tohto doplnku."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"Ak hľadáte viac užitočných doplnkov, môžete si pozrieť moju webovú stránku."

msgid "If you like this plugin, I would be happy about a review."
msgstr "Ak sa vám tento doplnok páči, budem vďačný za recenziu."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "Ohodnoťte tento doplnok."

msgid "Your detected country:"
msgstr "Vaša zistená krajina:"

msgid "Block all except my country"
msgstr "Blokovať všetko okrem mojej krajiny."

msgid "Unblock all"
msgstr "Odomknúť všetko."

msgid "Country"
msgstr "Krajina"

msgid "Status"
msgstr "Stav"

msgid "Block"
msgstr "Blokovať"

msgid "Blocked"
msgstr "Blokované"

msgid "Allowed"
msgstr "Povolené"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "Prístup z vašej krajiny (%s) bol blokovaný."
