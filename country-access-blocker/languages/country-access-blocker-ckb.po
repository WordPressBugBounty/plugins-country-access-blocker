msgid "Country Blocker"
msgstr "قەدەغەکردنی وڵات"

msgid "Settings saved."
msgstr "ڕێکخستنەکان پاشەکەوت کرا."

msgid "Unknown"
msgstr "نەناسراو"

msgid "Enable country blocking"
msgstr "قەدەغەکردنی وڵات چالاک بکە"

msgid "Enable IP-based country blocking"
msgstr "قەدەغەکردنی وڵات بە IP چالاک بکە"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "ئەم پلاگینە تەنها کاتێک قەدەغەکردنی بە IP چالاک بێت، کار دەکات."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"قەدەغەکردنی وڵات بە IP چالاک بکە (لە ip-api.com بەکار دەهێنێت | 45 داواکردن "
"لە هەر خولەکدا | وەشانی رایگان)"

msgid "Save settings"
msgstr "هەڵبژاردنەکان پاشەکەوت بکە"

msgid "Dismiss"
msgstr "رَدکردن"

msgid "Valeri"
msgstr "ڤالەری"

msgid "Hi, I'm Valeri 👋"
msgstr "سڵاو، من ڤالەریم 👋"

msgid "Thanks for using this plugin."
msgstr "سوپاس بۆ بەکارهێنانی ئەم پلاگینە."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"ئەگەر پێویستت بە پلاگینەکانی زیاتر کارا هەیە، دەتوانی ماڵپەڕەکەم سەیر بکەیت."

msgid "If you like this plugin, I would be happy about a review."
msgstr "ئەگەر ئەم پلاگینەیە پەسندت دەکات، خوشحال دەبم لە پێداچوونت."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "پلاگینەکە نمرە بدە."

msgid "Your detected country:"
msgstr "وڵاتی دۆزرایەوەی تۆ:"

msgid "Block all except my country"
msgstr "هەموو وڵات قەدەغە بکە، بەجگەی وڵاتی من."

msgid "Unblock all"
msgstr "سڕینەوەی قەدەغەکان"

msgid "Country"
msgstr "وڵات"

msgid "Status"
msgstr "حالەت"

msgid "Block"
msgstr "قەدەغە بکە"

msgid "Blocked"
msgstr "قەدەغەکراو"

msgid "Allowed"
msgstr "ڕێگەدراو"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "دەسترس لە وڵاتی تۆ (%s) قەدەغە کراوە."
