msgid "Country Blocker"
msgstr "Pemblokir Negara"

msgid "Settings saved."
msgstr "Pengaturan disimpan."

msgid "Unknown"
msgstr "Tidak diketahui"

msgid "Enable country blocking"
msgstr "Aktifkan pemblokiran negara"

msgid "Enable IP-based country blocking"
msgstr "Aktifkan pemblokiran negara berbasis IP"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "Plugin ini hanya bekerja jika pemblokiran berbasis IP diaktifkan."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"Aktifkan pemblokiran negara berbasis IP (menggunakan ip-api.com | 45 "
"permintaan per menit | Versi Gratis)"

msgid "Save settings"
msgstr "Simpan pengaturan"

msgid "Dismiss"
msgstr "Tutup"

msgid "Valeri"
msgstr "Valeri"

msgid "Hi, I'm Valeri 👋"
msgstr "Hai, saya Valeri 👋"

msgid "Thanks for using this plugin."
msgstr "Terima kasih telah menggunakan plugin ini."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"Jika Anda mencari plugin yang lebih berguna, Anda bisa mengunjungi situs web"
" saya."

msgid "If you like this plugin, I would be happy about a review."
msgstr ""
"Jika Anda menyukai plugin ini, saya akan senang jika Anda memberikan ulasan."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "Berikan peringkat plugin ini"

msgid "Your detected country:"
msgstr "Negara yang terdeteksi:"

msgid "Block all except my country"
msgstr "Blokir semua kecuali negara saya"

msgid "Unblock all"
msgstr "Buka blokir semua"

msgid "Country"
msgstr "Negara"

msgid "Status"
msgstr "Status"

msgid "Block"
msgstr "Blokir"

msgid "Blocked"
msgstr "Diblokir"

msgid "Allowed"
msgstr "Diizinkan"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "Akses dari negara Anda (%s) telah diblokir."
