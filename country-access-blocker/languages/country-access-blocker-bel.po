msgid "Country Blocker"
msgstr "Блакіроўка краін"

msgid "Settings saved."
msgstr "Наладкі захаваны."

msgid "Unknown"
msgstr "Невядомы"

msgid "Enable country blocking"
msgstr "Уключыць блакіроўку краін"

msgid "Enable IP-based country blocking"
msgstr "Уключыць блакіроўку краін па IP-адрасе"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "Гэты плагін працуе толькі тады, калі ўключана блакіроўка краін па IP."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"Уключыць блакіроўку краін па IP (выкарыстоўвае ip-api.com | 45 запытаў у "
"хвіліну | Бясплатная версія)"

msgid "Save settings"
msgstr "Захаваць налады"

msgid "Dismiss"
msgstr "Закрыць"

msgid "Valeri"
msgstr "Валеры"

msgid "Hi, I'm Valeri 👋"
msgstr "Прывітанне, я Валеры 👋"

msgid "Thanks for using this plugin."
msgstr "Дзякуй за выкарыстанне гэтага плагіна."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr "Калі вы шукаеце больш карысных плагінаў, вы можаце наведаць мой сайт."

msgid "If you like this plugin, I would be happy about a review."
msgstr "Калі вам падабаецца гэты плагін, буду рады пакінуць водгук."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "Ацаніце гэты плагін"

msgid "Your detected country:"
msgstr "Ваша выяўленая краіна:"

msgid "Block all except my country"
msgstr "Блакуй усе, акрамя маёй краіны."

msgid "Unblock all"
msgstr "Разблакаваць усе"

msgid "Country"
msgstr "Краіна"

msgid "Status"
msgstr "Статус"

msgid "Block"
msgstr "Блакаваць"

msgid "Blocked"
msgstr "Заблакаваная"

msgid "Allowed"
msgstr "Дазволена"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "Доступ з вашай краіны (%s) заблакаваны."
