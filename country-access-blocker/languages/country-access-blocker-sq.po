msgid "Country Blocker"
msgstr "Bllokues i shteteve"

msgid "Settings saved."
msgstr "Cilësimet u ruajtën."

msgid "Unknown"
msgstr "I panjohur"

msgid "Enable country blocking"
msgstr "Aktivizo bllokimin e shteteve"

msgid "Enable IP-based country blocking"
msgstr "Aktivizo bllokimin bazuar në IP"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "Ky shtojcë punon vetëm kur bllokimi me bazë IP është aktivizuar."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"Aktivizo bllokimin e shteteve bazuar në IP (përdor ip-api.com | 45 kërkesa "
"në minutë | Versioni falas)"

msgid "Save settings"
msgstr "Ruaj cilësimet"

msgid "Dismiss"
msgstr "Mbyll"

msgid "Valeri"
msgstr "Valeri"

msgid "Hi, I'm Valeri 👋"
msgstr "Përshëndetje, unë jam Valeri 👋"

msgid "Thanks for using this plugin."
msgstr "Faleminderit për përdorimin e këtij shtojcës."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"Nëse po kërkoni shtojca më të dobishme, mund të vizitoni faqen time në "
"internet."

msgid "If you like this plugin, I would be happy about a review."
msgstr "Nëse e pëlqeni këtë shtojcë, do të isha i lumtur për një vlerësim."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "Vlerëso këtë shtojcë."

msgid "Your detected country:"
msgstr "Shteti juaj i zbuluar:"

msgid "Block all except my country"
msgstr "Blloko të gjitha përveç shtetit tim"

msgid "Unblock all"
msgstr "Hiq bllokimin për të gjitha shtetet."

msgid "Country"
msgstr "Shteti"

msgid "Status"
msgstr "Statusi"

msgid "Block"
msgstr "Blloko"

msgid "Blocked"
msgstr "Bllokuar"

msgid "Allowed"
msgstr "Lejuar"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "Qasja nga shteti juaj (%s) është bllokuar."
