msgstr "Hamısını blokdan çıxarın."

msgid "Country"
msgstr "Ölkə"

msgid "Status"
msgstr "Vəziyyət"

msgid "Block"
msgstr "Blokla"

msgid "Blocked"
msgstr "Bloklandı."

msgid "Allowed"
msgstr "İcazə verildi."

