msgid "Country Blocker"
msgstr "Өлкө блокироваччы"

msgid "Settings saved."
msgstr "Настройкалар сакталды."

msgid "Unknown"
msgstr "Белгилүү эмес"

msgid "Enable country blocking"
msgstr "Өлкө тоскооллоону иштет"

msgid "Enable IP-based country blocking"
msgstr "IP-баскалан өлкөн тоскооллоону иштет"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "IP-нээс тоскооллоо актив болгондо гана бу плагин иштейт."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"IP-нээс өлкөн тоскооллоону иштет (ip-api.com | 45 суроо минутада | Free "
"Version)"

msgid "Save settings"
msgstr "Сакталары сакталла"

msgid "Dismiss"
msgstr "Кайырыл"

msgid "Valeri"
msgstr "Валери"

msgid "Hi, I'm Valeri 👋"
msgstr "Саҥа, мин Валери 👋"

msgid "Thanks for using this plugin."
msgstr "Бул плагинди колдонгонуҥа ыраазычылык билдирдиҥ."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr "Көңүлдүү плагиндерди издесеңиз, сайтымды караңыз."

msgid "If you like this plugin, I would be happy about a review."
msgstr "Бул плагинди жактыырсам, баалоо менен ыраасым."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "Бул плагинди баалаңыз"

msgid "Your detected country:"
msgstr "Сиздин табылган өлкөн:"

msgid "Block all except my country"
msgstr "Өлкөн туку бар бардыгын тоскооллоо"

msgid "Unblock all"
msgstr "Бардыгын тоскооллоо"

msgid "Country"
msgstr "Өлкө"

msgid "Status"
msgstr "Статус"

msgid "Block"
msgstr "Тоскооллоо"

msgid "Blocked"
msgstr "Тоскооллоох"

msgid "Allowed"
msgstr "Куус"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "Сиздин өлкө (%s) тоскооллогон."
