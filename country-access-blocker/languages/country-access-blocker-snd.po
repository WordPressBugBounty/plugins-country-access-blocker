msgid "Country Blocker"
msgstr "ملڪ بلاڪر"

msgid "Settings saved."
msgstr "سيٽنگون محفوظ ڪيون ويون."

msgid "Unknown"
msgstr "نامعلوم"

msgid "Enable country blocking"
msgstr "ملڪ بلاڪنگ کي فعال ڪريو"

msgid "Enable IP-based country blocking"
msgstr "IP تي ٻڌل ملڪ بلاڪنگ فعال ڪريو"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "هي پلگ ان صرف تڏهن ڪم ڪندو جڏهن IP-تي ٻڌل بلاڪنگ فعال هوندي."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"IP-تي ٻڌل ملڪ بلاڪنگ کي فعال ڪريو (ip-api.com استعمال ڪري ٿو | في منٽ 45 "
"درخواستون | مفت ورزن)"

msgid "Save settings"
msgstr "سيٽنگون محفوظ ڪريو"

msgid "Dismiss"
msgstr "رد ڪريو"

msgid "Valeri"
msgstr "واليري"

msgid "Hi, I'm Valeri 👋"
msgstr "هاءِ، آءُ واليري آهيان 👋"

msgid "Thanks for using this plugin."
msgstr "هن پلگ ان کي استعمال ڪرڻ لاءِ مهرباني."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"جيڪڏهن توهان وڌيڪ مددگار پلگ ان ڳولي رهيا آهيو، ته توهان منهنجي ويب سائيٽ "
"ڏسي سگهو ٿا."

msgid "If you like this plugin, I would be happy about a review."
msgstr ""
"جيڪڏهن توهان هن پلگ ان کي پسند ڪيو ته منهنجي لاءِ جائزو ڏيڻ ۾ خوشي ٿيندي."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "هن پلگ ان کي ريٽ ڏيو"

msgid "Your detected country:"
msgstr "توهان جو معلوم ٿيل ملڪ:"

msgid "Block all except my country"
msgstr "سڀ بلاڪ ڪريو سواءِ منهنجي ملڪ جي."

msgid "Unblock all"
msgstr "سڀ بلاڪ ختم ڪريو"

msgid "Country"
msgstr "ملڪ"

msgid "Status"
msgstr "حالت"

msgid "Block"
msgstr "بلاڪ"

msgid "Blocked"
msgstr "بلاڪ ٿيل"

msgid "Allowed"
msgstr "اجازت ٿيل"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "توهان جي ملڪ (%s) کان رسائي بلاڪ ڪئي وئي آهي."
