msgid "Country Blocker"
msgstr "Blocador de països"

msgid "Settings saved."
msgstr "Configuració desada."

msgid "Unknown"
msgstr "Desconegut"

msgid "Enable country blocking"
msgstr "Activa el bloqueig de països"

msgid "Enable IP-based country blocking"
msgstr "Activa el bloqueig de països basat en IP"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr ""
"Aquest plugin només funciona quan el bloqueig basat en IP està activat."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"Activa el bloqueig de països basat en IP (fa servir ip-api.com | 45 "
"sol·licituds per minut | Versió gratuïta)"

msgid "Save settings"
msgstr "Desa la configuració"

msgid "Dismiss"
msgstr "Tancar"

msgid "Valeri"
msgstr "Valeri"

msgid "Hi, I'm Valeri 👋"
msgstr "Hola, sóc en Valeri 👋"

msgid "Thanks for using this plugin."
msgstr "Gràcies per utilitzar aquest plugin."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr "Si busques més plugins útils, pots visitar el meu lloc web."

msgid "If you like this plugin, I would be happy about a review."
msgstr "Si t'agrada aquest plugin, m'agradaria rebre una valoració."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "Valora aquest plugin"

msgid "Your detected country:"
msgstr "El teu país detectat:"

msgid "Block all except my country"
msgstr "Bloqueja tot menys el meu país"

msgid "Unblock all"
msgstr "Desbloqueja tot"

msgid "Country"
msgstr "País"

msgid "Status"
msgstr "Estat"

msgid "Block"
msgstr "Bloquejar"

msgid "Blocked"
msgstr "Bloquejat"

msgid "Allowed"
msgstr "Permès"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "L'accés des del teu país (%s) ha estat bloquejat."
