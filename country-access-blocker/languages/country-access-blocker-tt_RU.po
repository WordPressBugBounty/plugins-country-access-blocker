msgid "Country Blocker"
msgstr "Илне блоклаучы"

msgid "Settings saved."
msgstr "Көйләүләр сакланды."

msgid "Unknown"
msgstr "Билгесез"

msgid "Enable country blocking"
msgstr "Илне блоклауны кабызу"

msgid "Enable IP-based country blocking"
msgstr "IP нигезле ил блоклауны кабызу"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "Бу плагин IP нигезле блоклау актив булган вакытта гына эшли."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"IP нигезле ил блоклауны активлаштыру (ip-api.com куллана | минутына 45 сорау"
" | Бушлай версия)"

msgid "Save settings"
msgstr "Көйләүләрне саклау"

msgid "Dismiss"
msgstr "Бетерү"

msgid "Valeri"
msgstr "Valeri"

msgid "Hi, I'm Valeri 👋"
msgstr "Сәлам, мин Валери 👋"

msgid "Thanks for using this plugin."
msgstr "Бу плагинны кулланганыгыз өчен рәхмәт."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"Әгәр дә тагын файдалы плагиннар эзлисез икән, минем сайтка кереп карый "
"аласыз."

msgid "If you like this plugin, I would be happy about a review."
msgstr "Әгәр бу плагинны яратсагыз, бәя калдырсагыз мин бик шат булыр идем."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "Бу плагинны бәяләгез."

msgid "Your detected country:"
msgstr "Ачыкланган илегез:"

msgid "Block all except my country"
msgstr "Минем илдән башка барлык илләрне дә блоклагыз."

msgid "Unblock all"
msgstr "Барлык илләрне дә ачыгыз."

msgid "Country"
msgstr "Ил"

msgid "Status"
msgstr "Хәл"

msgid "Block"
msgstr "Блоклау"

msgid "Blocked"
msgstr "Блокланган"

msgid "Allowed"
msgstr "Рөхсәт ителгән"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "Сезнең илегездән керү (%s) блокланды."
