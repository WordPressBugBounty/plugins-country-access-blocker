msgid "Country Blocker"
msgstr "ملک بلاکر"

msgid "Settings saved."
msgstr "ترتیبات محفوظ ہو گئی ہیں。"

msgid "Unknown"
msgstr "نامعلوم"

msgid "Enable country blocking"
msgstr "ملک بلاکنگ فعال کریں"

msgid "Enable IP-based country blocking"
msgstr "آئی پی پر مبنی ملک بلاکنگ فعال کریں"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "یہ پلگ اِن صرف تبھی کام کرتا ہے جب IP پر مبنی بلاکنگ فعال ہو。"

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"آئی پی پر مبنی ملک بلاکنگ فعال کریں (ip-api.com استعمال کرتا ہے | فی منٹ 45 "
"درخواستیں | مفت ورژن)"

msgid "Save settings"
msgstr "ترتیبات محفوظ کریں"

msgid "Dismiss"
msgstr "بند کریں"

msgid "Valeri"
msgstr "والیری"

msgid "Hi, I'm Valeri 👋"
msgstr "ہیلو، میں والیری ہوں 👋"

msgid "Thanks for using this plugin."
msgstr "اس پلگ اِن کے استعمال کا شکریہ。"

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"اگر آپ مزید کارآمد پلگ انز دیکھنا چاہتے ہیں، تو میری ویب سائٹ دیکھ سکتے ہیں。"

msgid "If you like this plugin, I would be happy about a review."
msgstr "اگر آپ کو یہ پلگ اِن پسند آئے تو مجھے ریویو دینے پر خوشی ہوگی。"

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "اس پلگ اِن کو ریٹ کریں"

msgid "Your detected country:"
msgstr "آپ کا پتہ چلا ہوا ملک:"

msgid "Block all except my country"
msgstr "میرے ملک کے علاوہ سب بلاک کریں"

msgid "Unblock all"
msgstr "سب کی بلاکنگ ہٹا دیں"

msgid "Country"
msgstr "ملک"

msgid "Status"
msgstr "حالت"

msgid "Block"
msgstr "بلاک کریں"

msgid "Blocked"
msgstr "بلاک کیا ہوا"

msgid "Allowed"
msgstr "اجازت یافتہ"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "آپ کے ملک (%s) سے رسائی بلاک کر دی گئی ہے。"
