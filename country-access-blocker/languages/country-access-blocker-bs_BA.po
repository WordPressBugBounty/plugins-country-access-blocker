msgid "Country Blocker"
msgstr "Blokator zemalja"

msgid "Settings saved."
msgstr "Podešavanja su sačuvana."

msgid "Unknown"
msgstr "Nepoznat"

msgid "Enable country blocking"
msgstr "Omogući blokiranje zemalja"

msgid "Enable IP-based country blocking"
msgstr "Omogući blokiranje zemalja na osnovu IP adrese"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "Ovaj dodatak radi samo kada je blokiranje po IP adresi omogućeno."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"Omogući blokiranje zemalja po IP adresi (koristi ip-api.com | 45 zahtjeva po"
" minutu | Besplatna verzija)"

msgid "Save settings"
msgstr "Spremi podešavanja"

msgid "Dismiss"
msgstr "Odbaci"

msgid "Valeri"
msgstr "Valeri"

msgid "Hi, I'm Valeri 👋"
msgstr "Zdravo, ja sam Valeri 👋"

msgid "Thanks for using this plugin."
msgstr "Hvala što koristite ovaj dodatak."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"Ako tražite više korisnih dodataka, možete posjetiti moju web stranicu."

msgid "If you like this plugin, I would be happy about a review."
msgstr "Ako vam se sviđa ovaj dodatak, bio bih zahvalan na recenziji."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "Ocijeni ovaj dodatak"

msgid "Your detected country:"
msgstr "Vaša otkrivena zemlja:"

msgid "Block all except my country"
msgstr "Blokiraj sve osim moje zemlje."

msgid "Unblock all"
msgstr "Otključaj sve"

msgid "Country"
msgstr "Zemlja"

msgid "Status"
msgstr "Status"

msgid "Block"
msgstr "Blokiraj"

msgid "Blocked"
msgstr "Blokirano"

msgid "Allowed"
msgstr "Dozvoljeno"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "Pristup iz vaše zemlje (%s) je blokiran."
