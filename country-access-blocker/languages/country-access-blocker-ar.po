msgid "Country Blocker"
msgstr "مانع الدول"

msgid "Settings saved."
msgstr "تم حفظ الإعدادات."

msgid "Unknown"
msgstr "غير معروف"

msgid "Enable country blocking"
msgstr "تمكين حظر الدول"

msgid "Enable IP-based country blocking"
msgstr "تمكين حظر الدول بناءً على عنوان IP"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr "تعمل هذه الإضافة فقط عندما يتم تمكين الحظر القائم على IP."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"تمكين حظر الدول بناءً على IP (يستخدم ip-api.com | 45 طلب في الدقيقة | "
"الإصدار المجاني)"

msgid "Save settings"
msgstr "حفظ الإعدادات"

msgid "Dismiss"
msgstr "إغلاق"

msgid "Valeri"
msgstr "فاليري"

msgid "Hi, I'm Valeri 👋"
msgstr "مرحباً، أنا فاليري 👋"

msgid "Thanks for using this plugin."
msgstr "شكراً لاستخدامك هذه الإضافة."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr "إذا كنت تبحث عن إضافات مفيدة أكثر، يمكنك الاطلاع على موقعي."

msgid "If you like this plugin, I would be happy about a review."
msgstr "إذا أعجبتك هذه الإضافة، سأكون سعيداً بتقييمك لها."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "قيّم هذه الإضافة"

msgid "Your detected country:"
msgstr "الدولة المكتشفة لديك:"

msgid "Block all except my country"
msgstr "حظر الكل باستثناء دولتي"

msgid "Unblock all"
msgstr "إلغاء حظر الكل"

msgid "Country"
msgstr "الدولة"

msgid "Status"
msgstr "الحالة"

msgid "Block"
msgstr "حظر"

msgid "Blocked"
msgstr "محظور"

msgid "Allowed"
msgstr "مسموح"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "تم حظر الوصول من بلدك (%s)."
