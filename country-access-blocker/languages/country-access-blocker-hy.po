msgid "Country Blocker"
msgstr "Երկրի արգելափակիչ"

msgid "Settings saved."
msgstr "Կարգավորումները պահպանվել են."

msgid "Unknown"
msgstr "Անհայտ"

msgid "Enable country blocking"
msgstr "Միացնել երկրի արգելափակումը"

msgid "Enable IP-based country blocking"
msgstr "Միացնել IP-հիմնված երկրի արգելափակումը"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr ""
"Այս փլագինը գործում է միայն այն ժամանակ, երբ IP-հիմնված արգելափակումը "
"ակտիվացված է."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"IP-հիմնված երկրի արգելափակումը միացնել (օգտագործում է ip-api.com | 45 "
"հարցում/րոպե | Անվճար տարբերակ)"

msgid "Save settings"
msgstr "Պահպանել կարգավորումները."

msgid "Dismiss"
msgstr "Փակել"

msgid "Valeri"
msgstr "Վալերի"

msgid "Hi, I'm Valeri 👋"
msgstr "Բարև, ես Վալերի եմ 👋"

msgid "Thanks for using this plugin."
msgstr "Շնորհակալություն այս փլագինը օգտագործելու համար."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"Եթե հետաքրքրվում եք ավելի օգտակար պլագիններով, կարող եք այցելել իմ կայքը."

msgid "If you like this plugin, I would be happy about a review."
msgstr ""
"Եթե դուր է գալիս այս փլագինը, ուրախ կլինեմ ստանալ ձեր վերանայությունը."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "Տվեք այս փլագինին գնահատական."

msgid "Your detected country:"
msgstr "Ձեր հայտնաբերված երկիրը:"

msgid "Block all except my country"
msgstr "Բլոկավորել բոլորին, բացի իմ երկրից"

msgid "Unblock all"
msgstr "Հանել բոլոր արգելափակումները."

msgid "Country"
msgstr "Երկիր"

msgid "Status"
msgstr "Կարգավիճակ"

msgid "Block"
msgstr "Արգելափակել"

msgid "Blocked"
msgstr "Արգելափակված"

msgid "Allowed"
msgstr "Թույլատրված"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "Ձեր երկրի (%s) հասանելիությունը արգելափակված է."
