msgid "Country Blocker"
msgstr "Blokování zemí"

msgid "Settings saved."
msgstr "Nastavení uloženo."

msgid "Unknown"
msgstr "Neznámé"

msgid "Enable country blocking"
msgstr "Povolit blokování zemí"

msgid "Enable IP-based country blocking"
msgstr "Povolit blokování zemí na základě IP"

msgid "This plugin works only when IP-based blocking is enabled."
msgstr ""
"Tento plugin funguje pouze tehdy, když je povoleno blokování na základě IP."

msgid ""
"Enable IP-based country blocking (uses ip-api.com | 45 requests per minute |"
" Free Version)"
msgstr ""
"Povolit blokování zemí na základě IP (používá ip-api.com | 45 požadavků za "
"minutu | Zdarma verze)"

msgid "Save settings"
msgstr "Uložit nastavení"

msgid "Dismiss"
msgstr "Zavřít"

msgid "Valeri"
msgstr "Valeri"

msgid "Hi, I'm Valeri 👋"
msgstr "Ahoj, já jsem Valeri 👋"

msgid "Thanks for using this plugin."
msgstr "Děkujeme, že používáte tento plugin."

msgid ""
"If you are looking for more helpful plugins, you can check out my website."
msgstr ""
"Pokud hledáte další užitečné pluginy, můžete navštívit moje webové stránky."

msgid "If you like this plugin, I would be happy about a review."
msgstr "Pokud se vám tento plugin líbí, budu rád za recenzi."

msgid "premium-plugin.com"
msgstr "premium-plugin.com"

msgid "Rate this plugin"
msgstr "Ohodnoťte tento plugin."

msgid "Your detected country:"
msgstr "Vaše zjištěná země:"

msgid "Block all except my country"
msgstr "Zablokovat vše kromě mé země"

msgid "Unblock all"
msgstr "Odemknout vše"

msgid "Country"
msgstr "Země"

msgid "Status"
msgstr "Stav"

msgid "Block"
msgstr "Blokovat"

msgid "Blocked"
msgstr "Zablokováno"

msgid "Allowed"
msgstr "Povoleno"

#. translators: %s is the visitor's country code, e.g. 'DE' or 'US'
msgid "Access from your country (%s) has been blocked."
msgstr "Přístup z vaší země (%s) byl zablokován."
